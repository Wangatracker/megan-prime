// TRACKER
commands.push({
    name: 'tracker',
    description: 'Show database tracker statistics',
    aliases: ['dbstats'],
    async execute({ msg, from, sender, bot, sock, buttons }) {
        try {
            const stats = bot.db?.getStats ? bot.db.getStats() : { totalCommands: 0, totalUsers: 0, totalGroups: 0 };
            const uptime = process.uptime();
            const days = Math.floor(uptime / 86400);
            const hours = Math.floor((uptime % 86400) / 3600);
            const minutes = Math.floor((uptime % 3600) / 60);
            const statText = `рҹ“Ҡ *DATABASE STATS*\n\n` +
                `рҹ“Ё *Commands Run:* ${stats.totalCommands}\n` +
                `рҹ‘Ҙ *Users:* ${stats.totalUsers}\n` +
                `рҹ‘Ҙ *Groups:* ${stats.totalGroups}\n` +
                `вҸұпёҸ *Uptime:* ${days}d ${hours}h ${minutes}m\n\n` +
                `> Megan-Prime | TrackerWanga`;
            await sendWithButtons(sock, from, statText, msg, buttons);
        } catch (error) {
            console.error('Tracker error:', error);
            await sendWithButtons(sock, from, 'вқҢ Error getting tracker stats.\n\n> Megan-Prime | TrackerWanga', msg, buttons);
        }
    }
});


// API STATUS (Megan API)
commands.push({
    name: 'apistatus',
    description: 'Check Megan API server status',
    aliases: ['serverstatus', 'apistats'],
    async execute({ msg, from, sender, args, bot, sock, react, reply }) {
        await react('рҹ–ҘпёҸ');
        try {
            const data = await apiGet('/api/status');
            const s = data.result || data;
            let text = `рҹ–ҘпёҸ *Megan API Status*\n\n`;
            if (s.uptime) text += `вҸұпёҸ *Uptime:* ${s.uptime}\n`;
            if (s.version) text += `рҹ“Ң *Version:* ${s.version}\n`;
            if (s.status) text += `вң… *Status:* ${s.status}\n`;
            if (s.endpoints) text += `рҹ”ў *Endpoints:* ${s.endpoints}\n`;
            if (s.memory) text += `рҹ’ҫ *Memory:* ${s.memory}\n`;
            text += `\nрҹ“Ў ${CREATOR}\n\n${FOOTER}`;
            await sendButtonsMsg(sock, from, text, msg);
            await react('вң…');
        } catch (e) { await react('вқҢ'); await reply(`вқҢ *Failed*\n\n${FOOTER}`); }
    }
});


module.exports = { commands };
