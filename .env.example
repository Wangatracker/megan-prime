# Megan-Prime Bot Configuration
# Copy this file to .env and fill in your values

# WhatsApp Session (from pairing or QR scan)
SESSION=Megan~your_session_string_here

# Bot Settings
BOT_NAME=Megan-Prime
OWNER_NAME=TrackerWanga
OWNER_NUMBER=254119387715
PREFIX=.
MODE=public
TIMEZONE=Africa/Nairobi

# Features (on/off)
ANTI_DELETE=on
ANTI_CALL=off
AUTO_READ=off
AUTO_REACT=off
CHATBOT=off
AWAY_MODE=off
AWAY_MESSAGE=TrackerWanga is not available right now. I'm Megan-Prime, his AI assistant. How can I help you today?
BOT_LANGUAGE=en

# Database
DATABASE_ENABLED=true
DATABASE_PATH=./database.sqlite
